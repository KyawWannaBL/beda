rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // HELPER FUNCTIONS FOR ROLE-BASED ACCESS CONTROL
    // ============================================================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get user role from custom claims
    function getUserRole() {
      return request.auth.token.role;
    }
    
    // Check if user has specific role
    function hasRole(role) {
      return isAuthenticated() && getUserRole() == role;
    }
    
    // Check if user has any of the specified roles
    function hasAnyRole(roles) {
      return isAuthenticated() && getUserRole() in roles;
    }
    
    // Check if user is App Owner (ultimate authority)
    function isAppOwner() {
      return hasRole('APP_OWNER');
    }
    
    // Check if user is Super Admin or App Owner
    function isSuperAdmin() {
      return hasAnyRole(['SUPER_ADMIN', 'APP_OWNER']);
    }
    
    // Check if user is any type of admin
    function isAdmin() {
      return hasAnyRole([
        'APP_OWNER', 
        'SUPER_ADMIN', 
        'FINANCE_ADMIN', 
        'OPERATIONS_ADMIN', 
        'MARKETING_ADMIN', 
        'CUSTOMER_SERVICE_ADMIN'
      ]);
    }
    
    // Check if user is operational staff
    function isOperationalStaff() {
      return hasAnyRole(['RDR', 'DES', 'WH', 'SUP', 'SSM', 'SSR']);
    }
    
    // Check if user is business user
    function isBusinessUser() {
      return hasAnyRole([
        'MERCHANT', 
        'CUSTOMER', 
        'MARKETING', 
        'CUSTOMER_SERVICE', 
        'FINANCE_USER', 
        'ANALYST'
      ]);
    }
    
    // Check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ============================================================================
    // USER MANAGEMENT & AUTHENTICATION
    // ============================================================================
    
    // Users collection - stores user profiles and roles
    match /users/{userId} {
      // App Owner can read/write all users
      allow read, write: if isAppOwner();
      
      // Super Admin can read/write all users except App Owner
      allow read, write: if isSuperAdmin() && resource.data.role != 'APP_OWNER';
      
      // Admins can read all users but only write to their subordinates
      allow read: if isAdmin();
      allow write: if isAdmin() && 
        resource.data.role in [
          'RDR', 'DES', 'WH', 'SUP', 'SSM', 'SSR',
          'MERCHANT', 'CUSTOMER', 'MARKETING', 'CUSTOMER_SERVICE', 
          'FINANCE_USER', 'ANALYST'
        ];
      
      // Users can read/write their own profile
      allow read, write: if isOwner(userId);
      
      // Operational staff can read basic user info for their operations
      allow read: if isOperationalStaff() && 
        resource.data.role in ['MERCHANT', 'CUSTOMER'];
    }
    
    // User roles and permissions
    match /user_roles/{userId} {
      allow read, write: if isSuperAdmin();
      allow read: if isAdmin() || isOwner(userId);
    }
    
    // User activity logs
    match /user_activity/{activityId} {
      allow read: if isSuperAdmin();
      allow read: if isAdmin() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }
    
    // ============================================================================
    // OPERATIONAL DATA (SOP-BASED LOGISTICS)
    // ============================================================================
    
    // Tamper Tags - Core SOP functionality
    match /tamper_tags/{tagId} {
      // Supervisors and above can manage tags
      allow read, write: if hasAnyRole(['SUP', 'OPERATIONS_ADMIN', 'SUPER_ADMIN', 'APP_OWNER']);
      
      // Riders can read and update tags assigned to them
      allow read, update: if hasRole('RDR') && 
        resource.data.assignedTo == request.auth.uid;
      
      // Data entry can read tags for registration
      allow read: if hasRole('DES');
    }
    
    // Shipments - Main operational data
    match /shipments/{shipmentId} {
      // Admins have full access
      allow read, write: if isAdmin();
      
      // Operational staff can access based on their role
      allow read, write: if isOperationalStaff();
      
      // Merchants can access their own shipments
      allow read, write: if hasRole('MERCHANT') && 
        resource.data.merchantId == request.auth.uid;
      
      // Customers can read their own shipments
      allow read: if hasRole('CUSTOMER') && 
        resource.data.customerId == request.auth.uid;
      
      // Customer service can read all shipments for support
      allow read: if hasRole('CUSTOMER_SERVICE');
    }
    
    // Pickup Records
    match /pickup_records/{recordId} {
      allow read, write: if hasAnyRole(['RDR', 'DES', 'SUP', 'OPERATIONS_ADMIN']);
      allow read: if isAdmin();
    }
    
    // Warehouse Operations
    match /warehouse_operations/{operationId} {
      allow read, write: if hasAnyRole(['WH', 'SUP', 'OPERATIONS_ADMIN']);
      allow read: if isAdmin();
    }
    
    // Delivery Records
    match /delivery_records/{deliveryId} {
      allow read, write: if hasAnyRole(['SSR', 'RDR', 'SUP', 'OPERATIONS_ADMIN']);
      allow read: if isAdmin();
      allow read: if hasRole('CUSTOMER') && 
        resource.data.customerId == request.auth.uid;
    }
    
    // ============================================================================
    // FINANCIAL DATA & MERCHANT MANAGEMENT
    // ============================================================================
    
    // Financial transactions
    match /financial_transactions/{transactionId} {
      // Finance admins have full access
      allow read, write: if hasAnyRole(['FINANCE_ADMIN', 'SUPER_ADMIN', 'APP_OWNER']);
      
      // Finance users can read and create
      allow read, create: if hasRole('FINANCE_USER');
      
      // Merchants can read their own transactions
      allow read: if hasRole('MERCHANT') && 
        resource.data.merchantId == request.auth.uid;
      
      // Customers can read their COD transactions
      allow read: if hasRole('CUSTOMER') && 
        resource.data.customerId == request.auth.uid;
    }
    
    // Merchant profiles and settings
    match /merchants/{merchantId} {
      allow read, write: if hasAnyRole(['FINANCE_ADMIN', 'SUPER_ADMIN', 'APP_OWNER']);
      allow read, write: if hasRole('MERCHANT') && merchantId == request.auth.uid;
      allow read: if isOperationalStaff(); // For shipment operations
    }
    
    // Commission calculations
    match /commissions/{commissionId} {
      allow read, write: if hasAnyRole(['FINANCE_ADMIN', 'SUPER_ADMIN', 'APP_OWNER']);
      allow read: if hasRole('FINANCE_USER');
      allow read: if isOwner(resource.data.userId);
    }
    
    // Payment records
    match /payments/{paymentId} {
      allow read, write: if hasAnyRole(['FINANCE_ADMIN', 'SUPER_ADMIN', 'APP_OWNER']);
      allow read: if hasRole('FINANCE_USER');
      allow read: if hasRole('MERCHANT') && 
        resource.data.merchantId == request.auth.uid;
    }
    
    // ============================================================================
    // MARKETING & CUSTOMER ENGAGEMENT
    // ============================================================================
    
    // Marketing campaigns
    match /marketing_campaigns/{campaignId} {
      allow read, write: if hasAnyRole(['MARKETING_ADMIN', 'SUPER_ADMIN', 'APP_OWNER']);
      allow read, create, update: if hasRole('MARKETING');
      allow read: if isAdmin(); // Other admins can view campaigns
    }
    
    // Customer segments
    match /customer_segments/{segmentId} {
      allow read, write: if hasAnyRole(['MARKETING_ADMIN', 'SUPER_ADMIN', 'APP_OWNER']);
      allow read: if hasRole('MARKETING');
    }
    
    // Campaign analytics
    match /campaign_analytics/{analyticsId} {
      allow read, write: if hasAnyRole(['MARKETING_ADMIN', 'SUPER_ADMIN', 'APP_OWNER']);
      allow read: if hasAnyRole(['MARKETING', 'ANALYST']);
    }
    
    // ============================================================================
    // CUSTOMER SERVICE & SUPPORT
    // ============================================================================
    
    // Support tickets
    match /support_tickets/{ticketId} {
      // Service admins have full access
      allow read, write: if hasAnyRole(['CUSTOMER_SERVICE_ADMIN', 'SUPER_ADMIN', 'APP_OWNER']);
      
      // Customer service agents can handle tickets
      allow read, write: if hasRole('CUSTOMER_SERVICE');
      
      // Customers can create and read their own tickets
      allow read, create: if hasRole('CUSTOMER') && 
        resource.data.customerId == request.auth.uid;
      allow update: if hasRole('CUSTOMER') && 
        resource.data.customerId == request.auth.uid &&
        resource.data.status == 'open';
      
      // Merchants can create and read their own tickets
      allow read, create: if hasRole('MERCHANT') && 
        resource.data.merchantId == request.auth.uid;
    }
    
    // Live chat sessions
    match /chat_sessions/{sessionId} {
      allow read, write: if hasAnyRole(['CUSTOMER_SERVICE_ADMIN', 'CUSTOMER_SERVICE']);
      allow read, write: if isOwner(resource.data.customerId);
    }
    
    // Knowledge base
    match /knowledge_base/{articleId} {
      allow read, write: if hasAnyRole(['CUSTOMER_SERVICE_ADMIN', 'SUPER_ADMIN', 'APP_OWNER']);
      allow read: if hasRole('CUSTOMER_SERVICE');
      allow read: if isBusinessUser(); // All business users can read KB
    }
    
    // ============================================================================
    // ANALYTICS & REPORTING
    // ============================================================================
    
    // KPI data
    match /kpi_data/{kpiId} {
      // Admins have full access
      allow read, write: if isAdmin();
      
      // Analysts can read and create KPI data
      allow read, create: if hasRole('ANALYST');
      
      // Business users can read relevant KPIs
      allow read: if isBusinessUser();
    }
    
    // Reports
    match /reports/{reportId} {
      // Admins can generate and access all reports
      allow read, write: if isAdmin();
      
      // Analysts can create and read reports
      allow read, create: if hasRole('ANALYST');
      
      // Users can read reports they created or are shared with them
      allow read: if isAuthenticated() && (
        resource.data.createdBy == request.auth.uid ||
        request.auth.uid in resource.data.sharedWith
      );
    }
    
    // System analytics
    match /system_analytics/{analyticsId} {
      allow read, write: if isSuperAdmin();
      allow read: if isAdmin();
    }
    
    // ============================================================================
    // AUDIT & SECURITY
    // ============================================================================
    
    // Audit logs - Critical security data
    match /audit_logs/{logId} {
      // Only Super Admin and App Owner can access audit logs
      allow read: if isSuperAdmin();
      
      // System can always create audit logs
      allow create: if isAuthenticated();
    }
    
    // Security events
    match /security_events/{eventId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
    }
    
    // User blocks and suspensions
    match /user_blocks/{blockId} {
      allow read, write: if isSuperAdmin();
      allow read: if isAdmin() && resource.data.blockedBy == request.auth.uid;
    }
    
    // ============================================================================
    // SYSTEM CONFIGURATION
    // ============================================================================
    
    // System settings - Only highest level access
    match /system_settings/{settingId} {
      allow read, write: if isAppOwner();
      allow read: if isSuperAdmin();
    }
    
    // Feature flags
    match /feature_flags/{flagId} {
      allow read, write: if isSuperAdmin();
      allow read: if isAdmin();
    }
    
    // API configurations
    match /api_configs/{configId} {
      allow read, write: if isAppOwner();
      allow read: if isSuperAdmin();
    }
    
    // ============================================================================
    // NOTIFICATIONS & MESSAGING
    // ============================================================================
    
    // Notifications
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
      
      // Admins can create notifications for users
      allow create: if isAdmin();
      
      // System can create notifications
      allow create: if isAuthenticated();
    }
    
    // System announcements
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
    
    // ============================================================================
    // REAL-TIME COLLECTIONS
    // ============================================================================
    
    // Real-time tracking data
    match /tracking_data/{trackingId} {
      allow read: if isAuthenticated();
      allow write: if isOperationalStaff();
    }
    
    // Live dashboard data
    match /dashboard_data/{dashboardId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============================================================================
    // DEFAULT DENY RULE
    // ============================================================================
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}