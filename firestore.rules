rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function role() { return request.auth.token.role; }
    function isAdmin() {
      return signedIn() && (
        role() in ['APP_OWNER','SUPER_ADMIN','OPERATIONS_ADMIN','FINANCE_ADMIN','MARKETING_ADMIN','CUSTOMER_SERVICE_ADMIN']
      );
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users can read/write their own profile; admins can manage all
    match /users/{uid} {
      allow read, write: if isAdmin() || (signedIn() && request.auth.uid == uid);
    }

    // Example operational data (adjust collections to your actual structure)
    match /parcels/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /wayPlans/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin() || role() in ['SUPERVISOR','RIDER','DRIVER','HELPER','DATA_ENTRY'];
    }
  }
}
